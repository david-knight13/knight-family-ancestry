ield  listed.  I did find a ship named Thomas which sailed from Gravesend, England in late 1635; the ship's Master was Henry Tavener.  This reminded me that Gresham I's grandmother was named Taverner.  Could there be a connection here? \"}],\"sketch\":\"\",\"mem\":0,\"src\":4},{\"pos\":4153,\"gen\":13,\"id\":\"LH8W-C95\",\"name\":\"Mary Pamelia Killigrew\",\"life\":\"1622–1678\",\"bp\":\"County Armagh, Ireland\",\"dp\":\"Nansemond, Virginia, United States\",\"states\":[\"Virginia\"],\"primary\":\"Virginia\",\"score\":0,\"interesting\":false,\"ev\":[],\"sketch\":\"\",\"mem\":0,\"src\":1},{\"pos\":2077,\"gen\":12,\"id\":\"GV36-RVP\",\"name\":\"Elizabeth Sheppard\",\"life\":\"1650–Deceased\",\"bp\":\"Nansemond, Virginia, British Colonial America\",\"dp\":\"Nansemond, Virginia, British Colonial America\",\"states\":[\"Virginia\"],\"primary\":\"Virginia\",\"score\":0,\"interesting\":false,\"ev\":[],\"sketch\":\"\",\"mem\":0,\"src\":0},{\"pos\":4154,\"gen\":13,\"id\":\"MF47-142\",\"name\":\"Robert Shepherd\",\"life\":\"1604–1653\",\"bp\":\"\",\"dp\":\"Jamestown, Jefferson, Virginia, United States\",\"states\":[\"Virginia\"],\"primary\":\"Virginia\",\"score\":0,\"interesting\":false,\"ev\":[],\"sketch\":\"\",\"mem\":0,\"src\":14},{\"pos\":4155,\"gen\":13,\"id\":\"46K1-JND\",\"name\":\"Elizabeth Spencer\",\"life\":\"1624–1655\",\"bp\":\"\",\"dp\":\"Surry, Virginia, United States\",\"states\":[\"Virginia\"],\"primary\":\"Virginia\",\"score\":0,\"interesting\":false,\"ev\":[],\"sketch\":\"\",\"mem\":0,\"src\":0},{\"pos\":65,\"gen\":7,\"id\":\"K45W-8LB\",\"name\":\"Nancy Fagan Chaffin\",\"life\":\"1791–1867\",\"bp\":\"Caswell, North Carolina, United States\",\"dp\":\"Dahlgren, Hamilton, Illinois, United States\",\"states\":[\"North Carolina\",\"Illinois\"],\"primary\":\"North Carolina\",\"score\":2,\"interesting\":false,\"ev\":[{\"t\":\"RESIDENCE\",\"ti\":\"\",\"d\":\"1850\",\"pl\":\"Hamilton, Illinois, United States\",\"desc\":\"\"}],\"sketch\":\"\",\"mem\":1,\"src\":22},{\"p