"{\n \"count\": 1087,\n \"hits\": [\n  {\n   \"id\": \"9HWY-ZVX\",\n   \"name\": \"Captain Thomas Carter\",\n   \"life\": \"1630–1700\",\n   \"bp\": \"Bedfordshire, England, United Kingdom\",\n   \"dp\": \"Lancaster, Virginia, British Colonial America\",\n   \"flags\": [\n    \"MIL-name\",\n    \"MIL-event\",\n    \"IMMIGRATION\",\n    \"OCCUPATION\",\n    \"CIVIC-LEGAL\",\n    \"MEM30\"\n   ],\n   \"ev\": [\n    \"OTHER_EVENT::Immigration [1635] @Virginia, United States\",\n    \"OTHER_EVENT::Other [about 1640] @Bedfordshire, England\",\n    \"OTHER_EVENT::Indebted to John Carter for 20,852 pounds of tobacco [1 June 1654] @Lancaster, Virginia, British Colonial America :: Thomas Carter of Rappahannock River to be paid at or before 15 9ber next year at my now Dwelling House\",\n    \"OTHER_EVENT::Certificate of land granted for transporting 7 persons [6 February 1655] @Lancaster, Virginia, British Colonial America :: Susana Carter, (is this his first wife?), Wm *hirt?, Mary Smythe, An Hughs, Jos Maxy, Mark Smythe, ???? Lu*ard?\",\n    \"OTHER_EVENT::Bought John Carter's plantation, the 800 acre Barford plantation [18 September 1655] @Lancaster, Virginia, British Colonial America :: £412 curr monie of England to be paid in London to John Carter of Lancaster county by 10 Jun 1657, or perhaps in tobacco, plantation of John Carter, formerly Capt Wm Brocas. Diana Skipwith a witness.\",\n    \"OTHER_EVENT::Bought 560 acres from George Marsh on credit [14 January 1656] @Lancaster, Virginia, British Colonial America :: 8000 pounds tobacco, 4000 due 10 Oct 1658, the other 400 due one year later. Recorded 28 Jul 1657\",\n    \"MILITARY_SERVICE:: [about 1660] @Virginia, British Colonial America\",\n    \"OTHER_EVENT::Divided the 400 acres he owned with Ebbya Bonnison [2 August 1660] @Lancaster, Virginia, United States ::  Beginning at head of cove out of branch of Haddaways Creek, cove Corotomen Creek, Bonnison's land downward upon the Bay, above the marked trees Hugh Brent is contented to take.\",\n    \"OTHER_EVENT::Capt Thomas Carter, Court Justice [29 March 1664] @Lancaster, Virginia, British Colonial America\",\n    \"MILITARY_SERVICE:: [1667] @Lancaster, Virginia, British Colonial America :: Captain Lancaster Militia\",\n    \"OTHER_EVENT::Marriage to Katharine Dale [4 May 1670] @Lancaster, Virginia, British Colonial America :: Marriage\",\n    \"OCCUPATION:: [1671] @Virginia, United States :: Deputy Clerk for Edward Dale Lancaster Clerk of Court\",\n    \"OTHER_EVENT::Creditor in Lancaster County, Virginia [1671] @Lancaster, Virginia, British Colonial America :: Creditor\",\n    \"OTHER_EVENT::(Tax) Tithable List [1673] @Lancaster, Virginia, British Colonial America :: Named on Tithable List\",\n    \"OCCUPATION:: [1674] @Southhampton, New South Wales, Australia :: Virginia Merchant Attorney\",\n    \"OTHER_EVENT::Member [1677] @Lancaster, Virginia, British Colonial America :: Council of Burgess\",\n    \"OCCUPATION:: [1678] @Lancaster, Virginia, British Colonial America :: Attorney\",\n    \"OTHER_EVENT::Departure [16 May 1683] @London, England, United Kingdom\",\n    \"OTHER_EVENT::Edward Dale gifts slave boys to Katherine and Thomas [7 October 1687] @Lancaster, Virginia, British Colonial America :: Two negro boys James age about 7 and mulatto Robin about 5\",\n    \"OCCUPATION:: [1694] @Lancaster, Virginia, British Colonial America :: Appraiser\",\n    \"OCCUPATION:: [1698] @Lancaster, Virginia, British Colonial America :: Declined appointment as Court Justice\",\n    \"OTHER_EVENT::Probate of the Estate of Mr. Thomas Carter [1700] @Lancaster, Virginia, British Colonial America :: Probate\",\n    \"OTHER_EVENT::Will Written [16 August 1700] @Lancaster, Virginia, British Colonial America :: Abstract: Wife Katherine to have home plantation and one third remainder personal property, gave each son Edward, Thomas, John, Henry (in England) 100 acres each Thomas to get my now dwelling plantation with 100 acres after mother's death. James bequeathed Henry's land if he didn't return from Engla\",\n    \"OTHER_EVENT::Will Proved [14 November 1700] @Lancaster, Virginia, British Colonial America :: by the three witnesses\",\n    \"MILITARY_SERVICE:: :: Virginia Militia - Captain\",\n    \"OCCUPATION:: :: Tobacco Planter\",\n    \"OTHER_EVENT::Edward Dale \",\n    \"OTHER_EVENT::Edward Dale gifts slave boys to Katherine and Thomas\",\n    \"OTHER_EVENT::Arrival @United States\",\n    \"OTHER_FACT::Barford Plantation \"\n   ],\n   \"sketch\": \"\",\n   \"src\": 23,\n   \"col\": 22,\n   \"mem\": 30\n  },\n  {\n   \"id\": \"9XHM-V2M\",\n   \"name\": \"Thomas Brooke\",\n   \"life\": \"1660–1730\",\n   \"bp\": \"District 4, Prince George's, Maryland, British Colonial America\",\n   \"dp\": \"Prince George's, Maryland, British Colonial America\",\n   \"flags\": [\n    \"MIL-event\",\n    \"IMMIGRATION\",\n    \"OCCUPATION\",\n    \"CIVIC-LEGAL\",\n    \"MEM5\"\n   ],\n   \"ev\": [\n    \"ALTERNATE_NAME::\",\n    \"OTHER_EVENT::Laid out tracts \\\"The Gore\\\", \\\"Brooke's Chance\\\" [1680] @Calvert, Maryland, British Colonial America\",\n    \"MILITARY_SERVICE:: [about 1685] @Prince George's, Maryland, British Colonial America :: Commissioned Major of the Militia and promoted to Colonel\",\n    \"OTHER_EVENT::Laid out tracts \\\"Addition to Brooke Chance\\\" and \\\"Hogg Pen\\\". [1685] @Calvert, Maryland, British Colonial America\",\n    \"OCCUPATION:: [from 1685 to 1689] @Calvert, Maryland, British Colonial America :: Justice (removed in 1689 probably due to his opposition in the revolution Protestant Associators)\",\n    \"OTHER_EVENT::Laid out tracts \\\"Addition to Brookefield\\\" and \\\"The Grove Landing\\\" [1688] @Calvert, Maryland, British Colonial America\",\n    \"OCCUPATION:: [26 August 1691] @Maryland, British Colonial America :: Member of the Upper House (Royal Council) Nominated by Lord Baltimore.\",\n    \"OCCUPATION:: [1 May 1694] @Maryland, British Colonial America :: Took oat of office as a Justice of the Provincial Court\",\n    \"OTHER_EVENT::Laid out tracts \\\"The Forrest\\\", \\\"Dan\\\", \\\"Brookes Discovery\\\", and \\\"The Prospect\\\" [from 1694 to 1695] @Prince George's, Maryland, British Colonial America\",\n    \"OCCUPATION:: [1695] @Maryland, British Colonial America :: Deputy Secretary of Maryland\",\n    \"OTHER_EVENT::Court [June 1696] @Prince George's, Maryland, British Colonial America :: Ordred by this Court that Mary Shaw daughter of John Shaw Aged three\\nYear[s] or thereabouts be bound out to the honorable Thomas Brooke Esquire\\nAccording to Acct Of Assembly.\",\n    \"OCCUPATION:: [1699] @Maryland, British Colonial America :: Commissary General of the Province\",\n    \"OCCUPATION:: [from 1692 to 1707] @Maryland, British Colonial America :: Member of the Council of Maryland\",\n    \"OTHER_EVENT::Dismissed from all offices by Gov. John Seymour (1649-1709) for close Catholic ties. [1708] @Maryland, British Colonial America\",\n    \"OCCUPATION:: [from 1715 to 1722] @Maryland, British Colonial America :: Reappointed to the same positions after the colony reverted to Proprietary control.\",\n    \"OCCUPATION:: [1720] @Maryland, British Colonial America :: President of the Council of Maryland\",\n    \"OCCUPATION:: [1720] @Maryland, British Colonial America :: Acting Governor of Maryland (due to the departure of Gov. John Hart (d. 1740) until the arrival of Gov. Charles Calvert (1688-1734)\",\n    \"OTHER_EVENT::Dismissed from the King's Council (probably due to his membership in the Church of England) [1722] @Maryland, British Colonial America\",\n    \"OTHER_EVENT::Deed of Gift [5 August 1726] @Prince George's, Maryland, British Colonial America\",\n    \"OTHER_EVENT::At the time of his death he had amassed over 7,000 acres of land and his value was listed as 1,374 pounds, including 36 slaves. [7 January 1730] @District 4, Prince George's, Maryland, British Colonial America\",\n    \"OTHER_EVENT::Alternative Death [25 January 1730] @District 4, Prince George's, Maryland, United States\",\n    \"NOBILITY_TITLE:: :: Esquire\"\n   ],\n   \"sketch\": \"\",\n   \"src\": 25,\n   \"col\": 4,\n   \"mem\": 5\n  },\n  {\n   \"id\": \"LCRS-BDW\",\n   \"name\": \"Johannes Christian Lehman\",\n   \"life\": \"1700–1748\",\n   \"bp\": \"Speyerdorf, Neustadt an der Weinstraße, Rhineland-Palatinate, Germany\",\n   \"dp\": \"Philadelphia, Philadelphia, Pennsylvania, British Colonial America\",\n   \"flags\": [\n    \"IMMIGRATION\",\n    \"MEM3\"\n   ],\n   \"ev\": [\n    \"ALTERNATE_NAME::\",\n    \"ALTERNATE_NAME::\",\n    \"ALTERNATE_NAME::\",\n    \"ALTERNATE_NAME::\",\n    \"ALTERNATE_NAME::\",\n    \"ALTERNATE_NAME::\",\n    \"ALTERNATE_NAME::\",\n    \"ALTERNATE_NAME::\",\n    \"ALTERNATE_NAME::\",\n    \"ALTERNATE_NAME::\",\n    \"ALTERNATE_NAME::\",\n    \"ALTERNATE_NAME::\",\n    \"ALTERNATE_NAME::\",\n    \"ALTERNATE_NAME::\",\n    \"ALTERNATE_NAME::\",\n    \"ALTERNATE_NAME::\",\n    \"ALTERNATE_NAME::\",\n    \"OTHER_EVENT::Baptism [13 June 1700] @Lachen, Neustadt an der Haardt, Bavaria, Germany\",\n    \"OTHER_EVENT::Fact 1 [29 August 1730] @Philadelphia, Philadelphia, Pennsylvania, British Colonial America :: immigration records\",\n    \"OTHER_EVENT::Arrival [1731] @Philadelphia, Pennsylvania, United States\",\n    \"OTHER_EVENT::Fact 2  @Williams, Fayette, Pennsylvania, United States\",\n    \"OTHER_EVENT::names\",\n    \"OTHER_FACT::twins :: Christian K and Johannes C were twins\",\n    \"OTHER_EVENT::Fact 2 @Philadelphia, Pennsylvania, United States :: burial\"\n   ],\n   \"sketch\": \"\",\n   \"src\": 45,\n   \"col\": 23,\n   \"mem\": 3\n  },\n  {\n   \"id\": \"GMRK-XLS\",\n   \"name\": \"William Thornton Sr\",\n   \"life\": \"1622–1709\",\n   \"bp\": \"England\",\n   \"dp\": \"Stafford, Virginia, British Colonial America\",\n   \"flags\": [\n    \"CIVIC-LEGAL\",\n    \"MEM42\"\n   ],\n   \"ev\": [\n    \"ALTERNATE_NAME::\",\n    \"ALTERNATE_NAME::\",\n    \"OTHER_EVENT::Settled in Charles River (Original Shire) (later York Co.), VA 1642 • York Co., VA  [1642] @York, Virginia, British Colonial America :: Thorneton, Wm., 1642, (sponsored) by Wm. Prior, Gent., York Co. \",\n    \"OTHER_EVENT::Grant [10 August 1642] @Charles River, Virginia, British Colonial America\",\n    \"OTHER_EVENT::Charles River Changes to York County  [1643] @Virginia, British Colonial America\",\n    \"OTHER_EVENT:: Binds Himself To Look After Cattle Of Margaret Liptrot [11 May 1646] @York, Virginia, British Colonial America\",\n    \"OTHER_EVENT::Gloucester County Formed From York County [1651] @Virginia, British Colonial America\",\n    \"OTHER_EVENT::Grant [16 February 1666] @Petsworth Parish, Gloucester, Virginia, British Colonial America\",\n    \"OTHER_EVENT::Power of Attorney [27 September 1673] @Old Rappahannock, Virginia, British Colonial America\",\n    \"OTHER_EVENT::Deed [27 September 1673] @Old Rappahannock, Virginia, British Colonial America\",\n    \"OTHER_EVENT::Deed [16 July 1675] @Old Rappahannock, Virginia, British Colonial America\",\n    \"OTHER_EVENT::Bought 250 acres South Side Rappahannock river, adj his 350A [4 September 1677] @Old Rappahannock, Virginia, British Colonial America :: Paid Richard and Mary Glover 2000 pounds of tobacco, land adjoing his 350 acres he purchased of Glover earlier. Land in Rafes Creek a branch of Piscataway Creek. Wit: John and Rebecca Burgh\",\n    \"OTHER_EVENT::Gives wife Elizabeth a mare and yearling cow calf in lieu of her dower [4 November 1679] @Old Rappahannock, Virginia, British Colonial America ::  dower thirds in 600 acres he sold to Waters\",\n    \"OTHER_EVENT::Vestryman [from 1677 to 1706] @Petsworth Parish, Gloucester, Virginia, British Colonial America\",\n    \"OTHER_EVENT::Tax Land [1704] @Gloucester, Virginia, British Colonial America\",\n    \"OTHER_EVENT::Power of Attorney Signed 22 December 1708 [22 December 1708] @Richmond County, Virginia, British Colonial America\",\n    \"OTHER_FACT::THORNTON DNA PROJECT  ::  Luke was NOT William’s son ~ source info below\",\n    \"OTHER_FACT::William Thornton's Parents :: To date there is NO documented proof that William Thornton Sr's parents are Lord William Phillip Thornton Jr and Frances B. Robinson, or William of Eastcombe Thornton Sr and Barbara Westby, or William Thornton III and Bridgete Marshall, or Nicolas Thornton and Lady Anne Widdrington.\",\n    \"OTHER_FACT::There is no primary documentation to support Elisia/Alicia Billington as a wife of William Thornton Sr.\",\n    \"OTHER_FACT::United Kingdom was not formed until 1801.\",\n    \"OTHER_FACT::William Thornton ~ 4th Great Grandfather of President Zachary Taylor\",\n    \"OTHER_FACT::William Thornton ~ 3rd Great Grandfather of President James Madison\",\n    \"OTHER_FACT::William Thornton ~ 3rd Great Grandfather of Meriwether Lewis\"\n   ],\n   \"sketch\": \"\",\n   \"src\": 16,\n   \"col\": 7,\n   \"mem\": 42\n  },\n  {\n   \"id\": \"LCZR-WSL\",\n   \"name\": \"Col. John Catlett Jr.\",\n   \"life\": \"1658–1724\",\n   \"bp\": \"Old Rappahannock, Virginia, British Colonial America\",\n   \"dp\": \"Essex, Virginia, British Colonial America\",\n   \"flags\": [\n    \"MIL-name\",\n    \"MIL-event\",\n    \"OCCUPATION\",\n    \"CIVIC-LEGAL\",\n    \"MEM5\"\n   ],\n   \"ev\": [\n    \"ALTERNATE_NAME::\",\n    \"ALTERNATE_NAME::\",\n    \"ALTERNATE_NAME::\",\n    \"OTHER_EVENT::Office [1692] @Essex, Virginia, United States :: Justice of the Peace\",\n    \"OTHER_EVENT::Capt John Catlett to swear the appraisers [10 June 1693] @Old Rappahannock, Virginia, British Colonial America :: Saml Sallis?, Robert Keys? and Andrew Harrison do on second Tuesday July next at the plantation of Geo Hasslewood decd to appraise and inventory\",\n    \"OTHER_EVENT::Paid 600 lbs tobo for 2 wolves heads by Pitt, 7500 lbs tobo for Burgess [12 December 1693] @Old Rappahannock, Virginia, British Colonial America ::  His b-i-l Francis Taliaferro was paid 200 lbs of tobo for 1 wolf head by gun. Other payments are consistent with 200 lbs by gun and 300 lbs by pit\",\n    \"OTHER_EVENT::To Capt Joh Catlett for Burgess Expenses 5170 lbs tobacco [11 November 1695] @Old Rappahannock, Virginia, British Colonial America :: The 5170 pounds of tobacco apparently his salary as Burgess, He was also paid 600 pounds of tobacco for two wolves heads by Pitt\",\n    \"OTHER_EVENT::Office [from 1693 to 1702] :: Member, Virginia House of Burgesses\",\n    \"OTHER_EVENT::Office [1700] @Essex, Virginia, United States :: Coroner\",\n    \"OTHER_EVENT::Land Patent [20 October 1704] @Essex, Virginia, British Colonial America :: 817 acres in the freshes & on S. side the river, on the head of Pewamanesee Cr\",\n    \"OTHER_EVENT::Appoint John Cattlett, Gentleman, at Sheriff of ye county [about 10 April 1705] @Essex, Virginia, British Colonial America ::  Meet fourtwith at Courthouse to give oath\",\n    \"OCCUPATION:: [1705] @Essex, Virginia, British Colonial America :: Sheriff\",\n    \"OTHER_EVENT::Col John Catlett and Richard Covington, trustees deed ½ acre [15 July 1707] @Old Rappahannock, Virginia, British Colonial America :: lot #12 of Land in the Burgh of Rappahannock to Augustine Smith for 170 pounds. Part of 50 acre townsite trustees are to sell/ Wit: Henry Smith, Simon Bowlin, Stephen Sharp, Thomas Catlett\",\n    \"OTHER_EVENT::Military: Colonel with Essex, Virginia Colony Militia [1724] @Essex, Virginia, United States :: Colonel, British Colonial Army\",\n    \"OTHER_EVENT::LifeSketch :: John married first, a Miss Smith. Some researchers believe that she was a daughter of Maj. Lawrence Smith since deeds recorded in Spotsylvania Co., VA, to Jno Catlett, Jr. and Richard Buckner, in 1722, from Augustine Smith, the son of Major Lawrence Smith\",\n    \"OTHER_EVENT::Will and Probate @Virginia, British Colonial America :: Will written 18 Nove 1724. Proved 19 Jan 1725.\",\n    \"OTHER_FACT::Will named beneficiaries.\",\n    \"OTHER_FACT::Occupation: Member of House of Burgesses from Essex, Virginia Colony, British Colonial America :: 1693; 1696, 1700-1702\",\n    \"OTHER_FACT:: Justice of the County Court 1680 :: Essex, Virginia, British Colonial America\"\n   ],\n   \"sketch\": \"\",\n   \"src\": 24,\n   \"col\": 8,\n   \"mem\": 5\n  },\n  {\n   \"id\": \"LKQ6-8J1\",\n   \"name\": \"Maj. Thomas Brooke I\",\n   \"life\": \"1632–1676\",\n   \"bp\": \"Battle, Sussex, England\",\n   \"dp\": \"Calvert, Maryland, British Colonial America\",\n   \"flags\": [\n    \"MIL-name\",\n    \"IMMIGRATION\",\n    \"OCCUPATION\",\n    \"CIVIC-LEGAL\",\n    \"MEM5\"\n   ],\n   \"ev\": [\n    \"ALTERNATE_NAME::\",\n    \"IMMIGRATION:: [30 June 1650] @Calvert, Maryland, British Colonial America :: Arrived in Maryland with his father, Gov. Robert Brooke, Sr. (1602-1655).\",\n    \"OCCUPATION:: [1658] @Calvert, Maryland, British Colonial America :: Commissioned a Captain, commanding the Militia of Calvert County\",\n    \"OCCUPATION:: [1660] @Calvert, Maryland, British Colonial America :: Major in the Militia\",\n    \"OCCUPATION:: [about 1660] @Calvert, Maryland, British Colonial America :: Mayor of Battle Creek\",\n    \"OCCUPATION:: [1661] @Calvert, Maryland, British Colonial America :: Led an expedition against Native Americans.\",\n    \"OCCUPATION:: [from 1660 to 1667] @Calvert, Maryland, British Colonial America :: High Sheriff\",\n    \"OTHER_EVENT::\\\"Brookefield\\\" his chief residence. Now located in Prince George's County) [16 April 1664] @Calvert, Maryland, British Colonial America\",\n    \"OCCUPATION:: [from 1663 to 1669] @Calvert, Maryland, British Colonial America :: Burgess for Calvert County\",\n    \"OCCUPATION:: [1667] @Calvert, Maryland, British Colonial America :: Presiding Chief Justice\",\n    \"OTHER_EVENT::Patented \\\"Locust Thicket\\\" and \\\"Brookes Landing\\\" [2 May 1668] @Charles, Maryland, British Colonial America\",\n    \"OTHER_EVENT::Patented tracts \\\"Brooke's Content\\\" (April 2), \\\"Brooke's Grove\\\" (May 2) 